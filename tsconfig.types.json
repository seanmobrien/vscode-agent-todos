{
	"compilerOptions": {
		"module": "Node16",
		"target": "es2022",
		"moduleResolution": "node16",
		"moduleDetection": "auto",
		"declaration": true,
		"emitDeclarationOnly": true,
		"outDir": "dist/types",
		"stripInternal": false,
		"composite": false, // set true if using project references
		"skipLibCheck": false,
		"baseUrl": ".",
		"lib": [
			"es2022"
		],
		"types": [
			"node"
		],
		// "paths": { /* same as your main tsconfig */ }
	},
	"include": [
		"src/**/*.ts",
	],
	"exclude": [
		"node_modules",
		"src/test/**/*"
	],
}